# Instagram AI Analyzer - Configuration Guide
# Copy this file to .env and fill in your credentials

# ============================================================
# Instagram Configuration (CHOOSE ONE METHOD)
# ============================================================

# METHOD 1: Facebook Graph API (RECOMMENDED - Most Stable)
# Get your credentials from: https://developers.facebook.com/apps/
# 1. Create a Facebook App
# 2. Set up Instagram Graph API product
# 3. Generate a long-lived access token
# 4. Get your Business Account ID
INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_business_account_id_here

# METHOD 2: Legacy Instagram Credentials (DEPRECATED - instagrapi)
# Not recommended as it violates Instagram ToS and is less reliable
# Only use if Graph API is not available to you
# INSTAGRAM_USERNAME=your_instagram_username
# INSTAGRAM_PASSWORD=your_instagram_password

# ============================================================
# Google Gemini AI Configuration
# ============================================================
# Get your key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# ============================================================
# Flask Web Server Configuration
# ============================================================
FLASK_DEBUG=False
FLASK_PORT=5000

# ============================================================
# Application Settings
# ============================================================
SUMMARY_MAX_LENGTH=2000

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
# 
# 1. Graph API Setup (Recommended):
#    a. Go to https://developers.facebook.com/apps/
#    b. Create a new app
#    c. Add "Instagram Graph API" product
#    d. In Settings > Basic, find your App ID and App Secret
#    e. Generate a long-lived user access token with these permissions:
#       - instagram_basic
#       - instagram_content_publishing
#       - pages_manage_posts
#    f. Use Graph API Explorer to get your business account ID:
#       GET /me/accounts (to get page ID)
#       Then GET /{page_id}?fields=instagram_business_account
#    g. Fill in INSTAGRAM_ACCESS_TOKEN and INSTAGRAM_BUSINESS_ACCOUNT_ID
#
# 2. Gemini API Setup:
#    a. Go to https://makersuite.google.com/app/apikey
#    b. Click "Get API Key"
#    c. Copy your API key
#    d. Fill in GEMINI_API_KEY
#
# 3. Run the application:
#    pip install -r requirements.txt
#    python main.py
#
# ============================================================
# TROUBLESHOOTING
# ============================================================
#
# Issue: "Access token invalid"
# Solution: Generate a new long-lived token from Facebook App Dashboard
#
# Issue: "Rate limited by Instagram"
# Solution: The application includes automatic retry logic. Wait a few minutes.
#
# Issue: "Comments not fetching"
# Solution: Ensure your Business Account has proper permissions set
#
# Issue: "Gemini API errors"
# Solution: Check your API key is valid and has quota remaining
#
# ============================================================